---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import { getCategoryList, getSortedPostsList } from "@/utils/content-utils";
import { url } from "@/utils/url-utils";

interface Props {
	currentPostCategory?: string;
}

const { currentPostCategory } = Astro.props as Props;

const categories = await getCategoryList();
// 提取置顶分类并与其他分类分开
const highlightNames = ["AI日报", "热门仓库"];
const highlightedCategories = categories.filter(cat => highlightNames.includes(cat.name));
const normalCategories = categories.filter(cat => !highlightNames.includes(cat.name));

// 按照 highlightNames 的顺序对置顶分类进行排序
highlightedCategories.sort((a, b) => highlightNames.indexOf(a.name) - highlightNames.indexOf(b.name));

const totalPosts = (await getSortedPostsList()).length;
const homeUrl = url("/");
const archiveUrl = url("/archive/");
---

<div
  class="card-base category-bar p-3 onload-animation"
  id="category-bar"
  data-home-path={homeUrl}
  data-archive-path={archiveUrl}
  data-current-post-category={currentPostCategory || ""}
>
  <div class="category-bar-inner flex gap-2">
    <a
      href={homeUrl}
      class="category-pill text-sm px-2 py-1 rounded-lg shrink-0
             transition-colors duration-150 ease-out flex items-center justify-center"
      data-category-name=""
      aria-label={i18n(I18nKey.home)}
    >
      <Icon name="material-symbols:home-outline" class="text-[1.25rem]" />
    </a>
    <a
      href={archiveUrl}
      class="category-pill text-sm px-3 py-1 rounded-lg whitespace-nowrap shrink-0
             transition-colors duration-150 ease-out flex items-center justify-center"
      data-category-name="__archive__"
    >
      {i18n(I18nKey.archive)}
      <span class="text-xs opacity-60 ml-1">{totalPosts}</span>
    </a>
    <div class="category-divider shrink-0"></div>
    <div class="scroll-area relative">
      <div class="scroll-fade scroll-fade-left" aria-hidden="true"></div>
      <div class="category-scroll flex gap-2 overflow-x-auto">
        {/* 渲染置顶高亮的分类 */}
        {
          highlightedCategories.map((cat) => (
            <a
              href={cat.url}
              class="category-pill highlight-pill text-sm px-3 py-1 rounded-lg whitespace-nowrap
                     transition-colors duration-150 ease-out flex items-center justify-center relative overflow-hidden"
              data-category-name={cat.name}
            >
              <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 to-purple-500/10 dark:from-blue-400/10 dark:to-purple-400/10 z-0"></div>
              <span class="relative z-10 font-medium text-blue-700 dark:text-blue-300">{cat.name}</span>
              <span class="relative z-10 text-xs opacity-70 ml-1.5 text-blue-600 dark:text-blue-400">{cat.count}</span>
            </a>
          ))
        }
        
        {/* 如果有置顶分类和普通分类，添加一个小的视觉分隔 */}
        {highlightedCategories.length > 0 && normalCategories.length > 0 && (
          <div class="w-px h-4 bg-black/10 dark:bg-white/10 self-center mx-1"></div>
        )}

        {/* 渲染普通分类 */}
        {
          normalCategories.map((cat) => (
            <a
              href={cat.url}
              class="category-pill text-sm px-3 py-1 rounded-lg whitespace-nowrap
                     transition-colors duration-150 ease-out flex items-center justify-center"
              data-category-name={cat.name}
            >
              {cat.name}
              <span class="text-xs opacity-60 ml-1">{cat.count}</span>
            </a>
          ))
        }
      </div>
      <div class="scroll-fade scroll-fade-right" aria-hidden="true"></div>
    </div>
    
    <div id="ai-filter-wrap" class="flex items-center overflow-hidden transition-all duration-300 ease-out origin-right" style="max-width: 150px; opacity: 1; transform: translateX(0);">
      <div class="category-divider shrink-0 mr-2"></div>
      <button 
        id="ai-filter-btn"
        class="category-pill text-sm px-3 py-1 rounded-lg shrink-0 transition-colors duration-150 ease-out flex items-center justify-center gap-1"
        aria-label="Toggle AI Posts"
        title="隐藏 AI 生成的文章"
      >
        <Icon name="material-symbols:robot-2-outline-rounded" class="text-[1.25rem]" />
        <span class="hidden md:inline">过滤 AI</span>
      </button>
    </div>
  </div>
</div>

<style>
  #ai-filter-wrap.hide-filter {
    max-width: 0 !important;
    opacity: 0 !important;
    transform: translateX(20px) !important;
    pointer-events: none;
    margin-left: -0.5rem; /* 抵消父元素的 gap-2 (0.5rem) */
  }
  .category-bar {
    margin-bottom: 1rem;
  }
  .category-divider {
    width: 1px;
    align-self: stretch;
    background: var(--line-divider);
  }
  .scroll-area {
    flex: 1;
    min-width: 0;
    position: relative;
  }
  .scroll-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2.5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 300ms ease-in-out;
    z-index: 1;
  }
  .scroll-fade[data-visible] {
    opacity: 1;
  }
  .scroll-fade-left {
    left: 0;
    background: linear-gradient(to left, transparent, var(--card-bg));
  }
  .scroll-fade-right {
    right: 0;
    background: linear-gradient(to right, transparent, var(--card-bg));
  }
  :global(body.wallpaper-transparent) .scroll-fade {
    display: none;
  }
  .category-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .category-scroll::-webkit-scrollbar {
    display: none;
  }
  .category-pill {
    border: 1.5px solid var(--line-divider);
    color: var(--btn-content);
    background: transparent;
  }
  .category-pill:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: transparent;
  }
  .category-pill[data-active] {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }
  .category-pill[data-soft-active] {
    border-color: var(--line-divider);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    color: color-mix(in srgb, var(--primary) 72%, var(--btn-content));
  }
  .category-pill[data-soft-active]:hover {
    border-color: var(--line-divider);
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    color: color-mix(in srgb, var(--primary) 82%, var(--btn-content));
  }
  .category-pill[data-soft-active][data-active],
  .category-pill[data-soft-active][data-active]:hover {
    border-color: var(--line-divider);
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    color: color-mix(in srgb, var(--primary) 82%, var(--btn-content));
  }
  .category-pill[data-active]:hover {
    background: var(--primary);
    border-color: var(--primary);
    opacity: 0.9;
  }
  .category-pill.highlight-pill {
    border-color: color-mix(in srgb, var(--primary) 30%, transparent);
  }
  .category-pill.highlight-pill:hover {
    border-color: var(--primary);
    background: color-mix(in srgb, var(--primary) 5%, transparent);
  }
  .category-pill.highlight-pill[data-active] {
    background: var(--primary);
    border-color: var(--primary);
  }
  .category-pill.highlight-pill[data-active] span {
    color: white !important;
  }
</style>

<style is:global>
  body.filter-ai .post-card-item[data-is-ai="true"],
  body.filter-ai .post-card-wrapper[data-is-ai="true"] {
    display: none !important;
  }
</style>

<script is:inline>
  if (typeof localStorage !== 'undefined' && localStorage.getItem("filterAI") === "true") {
    document.documentElement.classList.add("filter-ai");
    // 也添加到 body 上，兼容不同的选择器习惯
    if (document.body) {
      document.body.classList.add("filter-ai");
    } else {
      document.addEventListener("DOMContentLoaded", () => {
        document.body.classList.add("filter-ai");
      });
    }
  }
</script>

<script>
  let delayedCategoryBarScrollTimer: number | undefined;

  function getCategoryBarState(bar: HTMLElement, currentUrl: URL) {
    const pathname = currentUrl.pathname.replace(/\/$/, "");
    const homePath = (bar.getAttribute("data-home-path") || "/").replace(/\/$/, "");
    const archivePath = (bar.getAttribute("data-archive-path") || "/archive").replace(/\/$/, "");
    const isHome = pathname === homePath || pathname === "" || pathname === "/" || pathname.startsWith("/page/");
    const isArchive = pathname === archivePath;

    return {
      isHome,
      isArchive,
      activeCategory: currentUrl.searchParams.get("category") || "",
      hasTag: currentUrl.searchParams.has("tag"),
      hasUncategorized: currentUrl.searchParams.has("uncategorized"),
    };
  }

  function setActiveCategory(bar: HTMLElement, currentUrl: URL) {
    const { isHome, isArchive, activeCategory, hasTag, hasUncategorized } =
      getCategoryBarState(bar, currentUrl);
    const postCategory = (bar.getAttribute("data-current-post-category") || "").trim();

    const pills = bar.querySelectorAll<HTMLAnchorElement>("a.category-pill");
    pills.forEach((pill) => {
      pill.removeAttribute("data-active");
      pill.removeAttribute("data-soft-active");
    });

    if (isHome) {
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-category-name=""]')
        ?.setAttribute("data-active", "");
      return;
    }

    if (activeCategory) {
      pills.forEach((pill) => {
        if (pill.getAttribute("data-category-name") === activeCategory) {
          pill.setAttribute("data-active", "");
        }
      });
      return;
    }

    if (isArchive && !hasTag && !hasUncategorized) {
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-category-name="__archive__"]')
        ?.setAttribute("data-active", "");
      return;
    }

    if (postCategory) {
      pills.forEach((pill) => {
        if (pill.getAttribute("data-category-name") === postCategory) {
          pill.setAttribute("data-soft-active", "");
        }
      });
    }
  }

  function scrollActiveCategoryIntoView(bar: HTMLElement, behavior: ScrollBehavior = "smooth") {
    const activePill =
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-active]') ||
      bar.querySelector<HTMLAnchorElement>('.category-pill[data-soft-active]');
    const scroll = bar.querySelector<HTMLElement>(".category-scroll");
    if (!activePill || !scroll) return;

    const scrollLeft = activePill.offsetLeft - scroll.offsetLeft - (scroll.clientWidth - activePill.offsetWidth) / 2;
    scroll.scrollTo({ left: Math.max(0, scrollLeft), behavior });
  }

  function shouldDeferCategoryScroll(bar: HTMLElement, currentUrl: URL) {
    const { isHome } = getCategoryBarState(bar, currentUrl);
    const isMobile = window.innerWidth < 1024;
    const isBannerMode = document.body.classList.contains("enable-banner");
    return isMobile && isBannerMode && !isHome;
  }

  function updateCategoryBar(
    currentUrl = new URL(window.location.href),
    options: { scrollBehavior?: ScrollBehavior; deferScroll?: boolean } = {},
  ) {
    const bar = document.getElementById("category-bar");
    if (!bar) return;

    const swupContainer = document.getElementById("swup-container");
    if (swupContainer) {
      const currentPostCategory = swupContainer.getAttribute("data-current-post-category") || "";
      bar.setAttribute("data-current-post-category", currentPostCategory);
    }

    setActiveCategory(bar, currentUrl);

    const deferScroll = options.deferScroll ?? shouldDeferCategoryScroll(bar, currentUrl);
    const scrollBehavior = options.scrollBehavior ?? (deferScroll ? "auto" : "smooth");

    if (delayedCategoryBarScrollTimer) {
      window.clearTimeout(delayedCategoryBarScrollTimer);
      delayedCategoryBarScrollTimer = undefined;
    }

    if (deferScroll) {
      // 等主内容上移完成后再定位分类，避免出现“先横向滚动后上移”的卡顿观感。
      delayedCategoryBarScrollTimer = window.setTimeout(() => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            scrollActiveCategoryIntoView(bar, scrollBehavior);
            updateScrollHint();
          });
        });
      }, 220);
      return;
    }

    scrollActiveCategoryIntoView(bar, scrollBehavior);
    updateScrollHint();
  }

  function initCategoryBarInteractions() {
    const bar = document.getElementById("category-bar");
    if (!bar || bar.dataset.clickBound === "true") return;

    bar.dataset.clickBound = "true";
    bar.addEventListener("click", (event) => {
      if (!(event.target instanceof Element)) return;

      const pill = event.target.closest<HTMLAnchorElement>("a.category-pill");
      if (!pill) return;

      if (
        event.defaultPrevented ||
        event.button !== 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.shiftKey ||
        event.altKey
      ) {
        return;
      }

      if (pill.target && pill.target !== "_self") return;

      const targetUrl = new URL(pill.href, window.location.href);
      if (targetUrl.origin !== window.location.origin) return;

      setActiveCategory(bar, targetUrl);
      scrollActiveCategoryIntoView(bar, "auto");
    });
  }

  function initScrollFeatures() {
    const bar = document.getElementById("category-bar");
    if (!bar) return;

    const scroll = bar.querySelector<HTMLElement>(".category-scroll");
    if (!scroll) return;

    if (scroll.dataset.featuresBound === "true") {
      updateScrollHint();
      return;
    }
    scroll.dataset.featuresBound = "true";

    // 鼠标滚轮横向滚动
    scroll.addEventListener("wheel", (e) => {
      if (scroll.scrollWidth <= scroll.clientWidth) return;
      e.preventDefault();
      scroll.scrollLeft += e.deltaY;
    }, { passive: false });

    // 监听滚动更新提示图标
    scroll.addEventListener("scroll", updateScrollHint);
    window.addEventListener("resize", updateScrollHint);
    updateScrollHint();
  }

  function updateScrollHint() {
    const bar = document.getElementById("category-bar");
    if (!bar) return;
    const scroll = bar.querySelector<HTMLElement>(".category-scroll");
    const fadeLeft = bar.querySelector<HTMLElement>(".scroll-fade-left");
    const fadeRight = bar.querySelector<HTMLElement>(".scroll-fade-right");
    if (!scroll || !fadeLeft || !fadeRight) return;

    const hasOverflow = scroll.scrollWidth > scroll.clientWidth + 1;
    const atStart = scroll.scrollLeft <= 1;
    const atEnd = scroll.scrollLeft + scroll.clientWidth >= scroll.scrollWidth - 1;

    if (hasOverflow && !atStart) {
      fadeLeft.setAttribute("data-visible", "");
    } else {
      fadeLeft.removeAttribute("data-visible");
    }

    if (hasOverflow && !atEnd) {
      fadeRight.setAttribute("data-visible", "");
    } else {
      fadeRight.removeAttribute("data-visible");
    }
  }

  updateCategoryBar();
  initCategoryBarInteractions();
  initScrollFeatures();
  document.addEventListener("astro:page-load", () => {
    updateCategoryBar();
    initScrollFeatures();
  });
  document.addEventListener("swup:contentReplaced", () => {
    updateCategoryBar();
    // 某些 swup 生命周期下 URL/DOM 状态同步稍晚，下一帧再校正一次避免状态残留
    requestAnimationFrame(() => {
      updateCategoryBar();
    });
  });

  // 在 Swup 导航时提前更新状态，避免切换期间激活态闪烁
  function setupSwupEarlyUpdate() {
    if (!window.swup?.hooks) return;
    window.swup.hooks.on("visit:start", (visit: any) => {
      const bar = document.getElementById("category-bar");
      if (!bar) return;
      const targetUrl = new URL(visit.to.url, window.location.href);
      setActiveCategory(bar, targetUrl);
      
      // 在页面跳转前提前触发过滤按钮的动画
      const wrap = document.getElementById("ai-filter-wrap");
      if (wrap) {
        const isHome = targetUrl.pathname === "/" || targetUrl.pathname === "/index.html" || targetUrl.pathname.startsWith("/page/");
        if (!isHome) {
          wrap.classList.add("hide-filter");
        } else {
          wrap.classList.remove("hide-filter");
        }
      }
    });
  }
  if (window.swup?.hooks) {
    setupSwupEarlyUpdate();
  } else {
    document.addEventListener("swup:enable", setupSwupEarlyUpdate);
  }

  // AI 过滤逻辑
  function initAIFilter() {
    const btn = document.getElementById("ai-filter-btn");
    const wrap = document.getElementById("ai-filter-wrap");
    if (!btn || !wrap) return;
    
    // 检查是否在首页，如果不在首页则向右滑动隐藏
    const isHome = window.location.pathname === "/" || window.location.pathname === "/index.html" || window.location.pathname.startsWith("/page/");
    
    if (!isHome) {
      wrap.classList.add("hide-filter");
    } else {
      wrap.classList.remove("hide-filter");
    }

    if (btn.dataset.bound === "true") return;
    btn.dataset.bound = "true";

    // 默认不过滤（false）
    const isFiltered = localStorage.getItem("filterAI") === "true";
    
    function updateFilterState(filtered: boolean) {
      if (filtered) {
        document.documentElement.classList.add("filter-ai");
        document.body.classList.add("filter-ai");
        btn?.setAttribute("data-active", "");
        btn?.setAttribute("title", "显示 AI 生成的文章");
      } else {
        document.documentElement.classList.remove("filter-ai");
        document.body.classList.remove("filter-ai");
        btn?.removeAttribute("data-active");
        btn?.removeAttribute("title");
        btn?.setAttribute("title", "隐藏 AI 生成的文章");
      }
      
      // 触发 resize 事件以重新计算 Masonry 布局（如果有）
      window.dispatchEvent(new Event("resize"));
    }

    // 初始化状态
    updateFilterState(isFiltered);

    btn.addEventListener("click", () => {
      const currentState = document.documentElement.classList.contains("filter-ai");
      const newState = !currentState;
      localStorage.setItem("filterAI", String(newState));
      
      // 平滑动画过滤
      const container = document.getElementById("post-list-container");
      if (container) {
        container.classList.add("layout-switching");
        setTimeout(() => {
          updateFilterState(newState);
          requestAnimationFrame(() => {
            container.classList.remove("layout-switching");
          });
        }, 200); // 匹配 CSS 中的过渡时间
      } else {
        updateFilterState(newState);
      }
    });
  }

  initAIFilter();
  document.addEventListener("astro:page-load", initAIFilter);
  document.addEventListener("swup:contentReplaced", initAIFilter);
</script>
